<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.MainController"
      spacing="0" prefWidth="900" prefHeight="650">

    <HBox style="-fx-background-color: #2c3e50; -fx-padding: 10 15;" spacing="10">
        <Label text="💊 Gestion Pharmacie" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
    </HBox>

    <TabPane VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE">

        <Tab text="Médicaments">
            <fx:include source="MedicamentView.fxml"/>
        </Tab>

        <Tab text="Clients">
            <fx:include source="ClientView.fxml"/>
        </Tab>

        <Tab text="Ventes">
            <fx:include source="VenteView.fxml"/>
        </Tab>

    </TabPane>

</VBox>